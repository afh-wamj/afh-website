	<div style="margin-bottom: 1.5rem;"><a href="/" style="display: inline-block; background-color: #0066cc; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px; font-size: 0.9rem; margin-top: 1rem;">Back to Home</a></div></footer>
</body>
</html>
