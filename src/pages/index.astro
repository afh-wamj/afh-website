th: 100%; height: auto; border-radius: 8px; } .highlight-box { text-align: center; background: #f0f0f0; padding: 2rem; border-radius: 8px; margin-top: 2rem; } .highlight-box h3 { color: #2D5016; } .highlight-box a { color: #0066cc; text-decoration: none; font-weight: bold; } .highlight-box a:hover { text-decoration: underline; } ul { margin: 1rem 0 0 1.5rem; color: #666; } ul li { margin-bottom: 0.5rem; } .testimonials { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin: 2rem 0; } .testimonial-card { background: white; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2D5016; box-shadow: 0 2px 8px rgba(0,0,0,0.1); } .testimonial-card p { color: #555; font-style: italic; margin-bottom: 1rem; line-height: 1.7; } .testimonial-author { color: #2D5016; font-weight: bold; font-style: normal; } footer { background-color: #2D5016; color: white; text-align: center; padding: 2rem; margin-top: 3rem; font-size: 0.9rem; } .footer-contact { margin-bottom: 1rem; } .footer-contact a { color: #fff; text-decoration: none; } .footer-contact a:hover { text-decoration: underline; }</style></head><body><header><div class="header-content"><div class="logo">Adult Family Home</div><nav><a href="/">Home</a><a href="/about">About</a><a href="/services">Services</a><a href="/faq">FAQ</a><a href="/news">News</a><a href="/contact">Contact</a><a href="/legal">Legal</a></nav></div></header><div class="hero"><h1>Safe, home‑like living with consistent caregivers and personalized care.</h1><p>A warm, family-like environment in Kirkland, Washington</p><div class="hero-buttons"><a href="https://docs.google.com/forms/d/e/1FAIpQLSc6zOPC_-XkiE4FFxW-MbLW13HCLkGp7LDdFpJXXJlNcikH5Q/viewform?usp=header" class="btn" target="_blank">Schedule a Visit</a></div></div><div class="container"><div class="content-section"><h2>Welcome to Our Adult Family Home</h2><p>We provide personalized, compassionate care for adults who need support with daily living. Our home offers a safe, comfortable environment where residents receive individualized attention and meaningful engagement.</p></div><div class="image-grid"><img src="/images/1.png" alt="Front exterior - safe and welcoming"><img src="/images/4.png" alt="Caregiver assisting resident with dignity"></div><div class="content-section"><h3>Our Approach</h3><p>We believe care should be delivered with dignity, respect, and warmth. Every resident is treated as a valued member of our family, and we're committed to supporting their physical health, emotional well-being, and quality of life.</p></div><div class="image-grid"><img src="/images/2.png" alt="Living room - calm and social space"><img src="/images/5.png" alt="Residents enjoying meaningful activities"></div><div class="content-section"><h3>Why Choose Us?</h3><ul><li>Safe, comfortable home environment with 24/7 supervision</li><li>Personalized care plans tailored to individual needs</li><li>Experienced, compassionate caregivers</li><li>Nutritious, home-cooked meals</li><li>Social engagement and meaningful activities</li></ul></div><div class="content-section"><h3>What Families Say</h3><div class="testimonials"><div class="testimonial-card"><p>"My mother has thrived in this home. The care is attentive, the staff treats her like family, and I see her genuinely happy."</p><div class="testimonial-author">— Harry</div></div><div class="testimonial-card"><p>"The home feels warm and secure. My dad's needs are met with kindness and professionalism. I couldn't ask for more."</p><div class="testimonial-author">— Sally</div></div><div class="testimonial-card"><p>"This is the kind of place I want for my future. The residents are well cared for, and the team truly cares about each person."</p><div class="testimonial-author">— David</div></div><div class="testimonial-card"><p>"We felt supported from the first phone call through the admission and beyond. This is genuine, caring adult family home care."</p><div class="testimonial-author">— Ava</div></div></div></div><div class="highlight-box"><h3>Ready to Learn More?</h3><p style="margin: 1rem 0;">Explore our <a href="/about">about us</a>, <a href="/services">services</a>, <a href="/faq">FAQ</a>, or <a href="/contact">contact us</a> today.</p><a href="/contact" class="btn btn-secondary" style="margin-top: 1rem;">Get in Touch</a></div></div><footer><div class="footer-contact"><a href="tel:425-123-4567" style="color: #fff;">425-123-4567</a> | <a href="mailto:contact@afh.wamj@gmail.com" style="color: #fff;">contact@afh.wamj@gmail.com</a> | 7am–7pm, 7 days a week</div><p>&copy; 2026 Adult Family Home. All rights reserved.</p><div style="margin-bottom: 1.5rem;"><a href="/" style="display: inline-block; background-color: #0066cc; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px; font-size: 0.9rem; margin-top: 1rem;">Back to Home</a></div></footer></body></html>
